{
  "name": "playwrightautomationcucumber",
  "version": "1.0.0",
  "description": "Playwright + Cucumber BDD Automation Framework",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js --config cucumber.config.js",
    "test:headless": "cross-env HEADLESS=true cucumber-js --config cucumber.config.js",
    "test:smoketag": "cucumber-js --config cucumber.config.js --tags @smoke"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.8.1"
  }
}
